}

# Exemplo de resposta esperada para o primeiro usuario da empresa:
# {
#   "success": true,
#   "data": {
#     "id": "...",
#     "empresaId": "...",
#     "email": "alpha@empresa.com",
#     "nome": "Usuario Alpha",
#     "status": "Ativo",
#     "possuiSenhaConfigurada": false,
#     "permissoes": [],
#     "perfisAcesso": ["..."],
#     "bootstrapAdministrador": true
#   },
#   "error": null
# }

###

POST {{ERP.Api_HostAddress}}/identity/usuarios/{{usuarioCadastroId}}/senha
Content-Type: application/json
X-Session-Token: {{sessionToken}}

{
  "senha": "Senha@123",
  "ativarUsuario": true
}

###

POST {{ERP.Api_HostAddress}}/identity/auth/login
Content-Type: application/json

{
  "empresaId": "{{empresaId}}",
  "email": "alpha@empresa.com",
  "senha": "Senha@123"
}

###

POST {{ERP.Api_HostAddress}}/identity/oauth/token
Content-Type: application/json

{
  "empresaId": "{{empresaId}}",
  "email": "alpha@empresa.com",
  "senha": "Senha@123"
}

# Exemplo de resposta esperada:
# {
#   "success": true,
#   "data": {
#     "accessToken": "...",
#     "refreshToken": "...",
#     "tokenType": "Bearer",
#     "expiresAt": "...",
#     "sessao": {
#       "token": "...",
#       "expiresAt": "...",
#       "usuario": { "...": "..." }
#     }
#   },
#   "error": null
# }

###

POST {{ERP.Api_HostAddress}}/identity/oauth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

# Exemplo de resposta esperada:
# novo accessToken + novo refreshToken

