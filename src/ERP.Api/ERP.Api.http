POST {{ERP.Api_HostAddress}}/integracoes/webhooks
Content-Type: application/json
X-Webhook-Signature: {{webhookSignature}}

{
  "eventoId": "evt-1",
  "origem": "marketplace",
  "payload": "{\"pedido\":\"123\"}"
}

# Assinatura esperada: HMAC-SHA256 em hexadecimal minusculo do texto
# evt-1:marketplace:{"pedido":"123"}
# usando o segredo configurado em WebhookSecurity:SharedSecret.

###

GET {{ERP.Api_HostAddress}}/integracoes/webhooks?origem=marketplace&status=Processado&page=1&pageSize=20
Accept: application/json
